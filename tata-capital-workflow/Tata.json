    },
    {
      "parameters": {
        "jsCode": "// Split uploaded binary files into separate items and set a safe binary key\nconst results = [];\nfor (const item of items) {\n  if (!item.binary) continue;\n  for (const key of Object.keys(item.binary)) {\n    const origName = item.binary[key].fileName || key;\n    const safeKey = origName.replace(/\\s+/g, '_');\n    results.push({\n      json: { fileName: safeKey, originalName: origName },\n      binary: { [safeKey]: item.binary[key] },\n    });\n  }\n}\nreturn results;\n"
      },
